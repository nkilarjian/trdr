{
  "name": "trdr",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "description": "TRDR — graded trading-card portfolio & mispricing-signal app (monorepo)",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "e2e": "tsx scripts/e2e.ts",
    "backtest": "tsx scripts/backtest.ts",
