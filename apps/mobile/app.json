{
  "expo": {
    "name": "TRDR",
    "slug": "trdr",
    "scheme": "trdr",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.trdr.app"
    },
    "android": {
      "package": "com.trdr.app",
      "adaptiveIcon": {
        "backgroundColor": "#0b0e14",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single",
      "name": "TRDR",
      "shortName": "TRDR",
      "themeColor": "#0b0e14",
      "backgroundColor": "#0b0e14",
      "display": "standalone",
      "lang": "en",
      "description": "Find great graded-card deals and know what your cards are worth."
    },
    "plugins": [
      "expo-secure-store",
      "expo-web-browser"
    ]
  }
}
