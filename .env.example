# ─── TRDR environment (all unset by design; app runs fully on mocks) ───
# Set TRDR_PROVIDERS=mock (default) to run with fixtures and zero credentials.
TRDR_PROVIDERS=mock

# ── eBay (Phase 1) ──────────────────────────────────────────────
# Browse API — active listings (accessible with dev keys)
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_OAUTH_REDIRECT_URI=
# Sold/transaction data — GATED (data partner or accumulation). Do not hard-couple.
EBAY_SOLD_PARTNER_KEY=
# EPN affiliate wrapper for deep-link monetization
EBAY_EPN_CAMPAIGN_ID=

# ── Grading cert + pop (Phase 1) — GATED, per-grader approval ────
PSA_API_TOKEN=
CGC_API_TOKEN=
SGC_API_TOKEN=
BGS_API_TOKEN=

# ── Push (Phase 1) ──────────────────────────────────────────────
EXPO_ACCESS_TOKEN=

# ── eBay Offer API placeProxyBid (Phase 3) — FEATURE-FLAGGED OFF ─
FEATURE_AUTOBID=false

# ── Datastores (local dev via docker-compose) ───────────────────
DATABASE_URL=postgres://trdr:trdr@localhost:5432/trdr
REDIS_URL=redis://localhost:6379
MODEL_SERVICE_URL=http://localhost:8000
