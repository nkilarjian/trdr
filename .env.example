# ─── TRDR environment (all unset by design; app runs fully on mocks) ───
# Set TRDR_PROVIDERS=mock (default) to run with fixtures and zero credentials.
TRDR_PROVIDERS=mock

# ── eBay (Phase 1) ──────────────────────────────────────────────
# Browse API — active listings (accessible with standard dev keys). Setting
# both EBAY_CLIENT_ID + EBAY_CLIENT_SECRET switches market data to live eBay.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_OAUTH_REDIRECT_URI=
EBAY_MARKETPLACE_ID=EBAY_US
# Sold/transaction prices — eBay's Marketplace Insights API is SEPARATELY gated
# (apply for limited access). Without it, valuation stays low-confidence.
EBAY_SOLD_PARTNER_KEY=
# EPN affiliate wrapper for deep-link monetization
EBAY_EPN_CAMPAIGN_ID=

# ── Grading cert + pop (Phase 1) — GATED, per-grader approval ────
PSA_API_TOKEN=
CGC_API_TOKEN=
SGC_API_TOKEN=
BGS_API_TOKEN=

# ── Push (Phase 1) ──────────────────────────────────────────────
EXPO_ACCESS_TOKEN=

# ── Vision backend for "snap your collection" (reads slabs from a photo) ──
# Set VISION_BACKEND=claude + an Anthropic key to have Claude vision read the
# grader + cert from each slab in an uploaded photo. Default (unset) = mock.
VISION_BACKEND=
ANTHROPIC_API_KEY=
VISION_MODEL=claude-opus-4-8

# ── eBay Offer API placeProxyBid (Phase 3) — FEATURE-FLAGGED OFF ─
FEATURE_AUTOBID=false

# ── Datastores (local dev via docker-compose) ───────────────────
DATABASE_URL=postgres://trdr:trdr@localhost:5432/trdr
REDIS_URL=redis://localhost:6379
MODEL_SERVICE_URL=http://localhost:8000
